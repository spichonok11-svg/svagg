DATABASE_URL=
POSTGRES_DB=putevka
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60
LIVE_PARSER_ENABLED=1
PUTEVKA_SITEMAP_ENABLED=1
PUTEVKA_SITEMAP_REGIONS_LIMIT=250000
PUTEVKA_MIN_TOURS_TARGET=150000
PUTEVKA_REGION_BATCH_SIZE=900
PUTEVKA_DETAIL_PAGES_LIMIT=350000
PUTEVKA_DETAIL_BATCH_SIZE=400
PUTEVKA_FETCH_WORKERS=110
PUTEVKA_FETCH_TIMEOUT_SECONDS=20
PUTEVKA_PAGE_CACHE_TTL_SECONDS=1800
PUTEVKA_SITEMAP_CACHE_TTL_SECONDS=3600
PUTEVKA_DISPLAY_PRICE_CAP=100000
PUTEVKA_INCLUDE_FOREIGN=1
PUTEVKA_FOREIGN_ROOTS=abkhazia,belarus,chehija,italiya,turtsiya,oae,egipet,tailand,vietnam,gruziya,azerbaydzhan,armeniya,kazahstan,kyrgyzstan,serbiya,chernogoriya
